    Molecules  Growing_flagellar_hook_total  Growing_flagellar_hook()
    Molecules  Growing_flagella_total  Growing_flagella()
end observables

begin reaction rules

    # === flhDC ===
    # Product: flhDC
    # Subunits: 4x flhD, 2x flhC
    # Nucleation (rate scaled by 1/total_subunits)
    flhC() + flhC() -> Growing_flhDC(flhC~2,flhD~0)  k_nuc_flhDC
    Growing_flhDC(flhD~0) + flhD() -> Growing_flhDC(flhD~1)  k_bind
    Growing_flhDC(flhD~1) + flhD() -> Growing_flhDC(flhD~2)  k_bind
    Growing_flhDC(flhD~2) + flhD() -> Growing_flhDC(flhD~3)  k_bind
    Growing_flhDC(flhD~3) + flhD() -> Growing_flhDC(flhD~4)  k_bind
    # Completion
    Growing_flhDC(flhC~2,flhD~4) -> flhDC()  k_completion

    # === flagellar motor switch reaction ===
    # Product: flagellar motor switch
    # Subunits: 26x fliG, 34x fliM, 1x fliN
    # Nucleation (rate scaled by 1/total_subunits)
    fliN() + fliG() -> Growing_flagellar_motor_switch(fliG~1,fliM~0,fliN~1)  k_nuc_flagellar_motor_switch
    Growing_flagellar_motor_switch(fliG~1) + fliG() -> Growing_flagellar_motor_switch(fliG~2)  k_bind
    Growing_flagellar_motor_switch(fliG~2) + fliG() -> Growing_flagellar_motor_switch(fliG~3)  k_bind
    Growing_flagellar_motor_switch(fliG~3) + fliG() -> Growing_flagellar_motor_switch(fliG~4)  k_bind
    Growing_flagellar_motor_switch(fliG~4) + fliG() -> Growing_flagellar_motor_switch(fliG~5)  k_bind
    Growing_flagellar_motor_switch(fliG~5) + fliG() -> Growing_flagellar_motor_switch(fliG~6)  k_bind
    Growing_flagellar_motor_switch(fliG~6) + fliG() -> Growing_flagellar_motor_switch(fliG~7)  k_bind
    Growing_flagellar_motor_switch(fliG~7) + fliG() -> Growing_flagellar_motor_switch(fliG~8)  k_bind
    Growing_flagellar_motor_switch(fliG~8) + fliG() -> Growing_flagellar_motor_switch(fliG~9)  k_bind
    Growing_flagellar_motor_switch(fliG~9) + fliG() -> Growing_flagellar_motor_switch(fliG~10)  k_bind
    Growing_flagellar_motor_switch(fliG~10) + fliG() -> Growing_flagellar_motor_switch(fliG~11)  k_bind
    Growing_flagellar_motor_switch(fliG~11) + fliG() -> Growing_flagellar_motor_switch(fliG~12)  k_bind
    Growing_flagellar_motor_switch(fliG~12) + fliG() -> Growing_flagellar_motor_switch(fliG~13)  k_bind
    Growing_flagellar_motor_switch(fliG~13) + fliG() -> Growing_flagellar_motor_switch(fliG~14)  k_bind
    Growing_flagellar_motor_switch(fliG~14) + fliG() -> Growing_flagellar_motor_switch(fliG~15)  k_bind
    Growing_flagellar_motor_switch(fliG~15) + fliG() -> Growing_flagellar_motor_switch(fliG~16)  k_bind
    Growing_flagellar_motor_switch(fliG~16) + fliG() -> Growing_flagellar_motor_switch(fliG~17)  k_bind
    Growing_flagellar_motor_switch(fliG~17) + fliG() -> Growing_flagellar_motor_switch(fliG~18)  k_bind
    Growing_flagellar_motor_switch(fliG~18) + fliG() -> Growing_flagellar_motor_switch(fliG~19)  k_bind
    Growing_flagellar_motor_switch(fliG~19) + fliG() -> Growing_flagellar_motor_switch(fliG~20)  k_bind
    Growing_flagellar_motor_switch(fliG~20) + fliG() -> Growing_flagellar_motor_switch(fliG~21)  k_bind
    Growing_flagellar_motor_switch(fliG~21) + fliG() -> Growing_flagellar_motor_switch(fliG~22)  k_bind
    Growing_flagellar_motor_switch(fliG~22) + fliG() -> Growing_flagellar_motor_switch(fliG~23)  k_bind
    Growing_flagellar_motor_switch(fliG~23) + fliG() -> Growing_flagellar_motor_switch(fliG~24)  k_bind
    Growing_flagellar_motor_switch(fliG~24) + fliG() -> Growing_flagellar_motor_switch(fliG~25)  k_bind
    Growing_flagellar_motor_switch(fliG~25) + fliG() -> Growing_flagellar_motor_switch(fliG~26)  k_bind
    Growing_flagellar_motor_switch(fliM~0) + fliM() -> Growing_flagellar_motor_switch(fliM~1)  k_bind
    Growing_flagellar_motor_switch(fliM~1) + fliM() -> Growing_flagellar_motor_switch(fliM~2)  k_bind
    Growing_flagellar_motor_switch(fliM~2) + fliM() -> Growing_flagellar_motor_switch(fliM~3)  k_bind
    Growing_flagellar_motor_switch(fliM~3) + fliM() -> Growing_flagellar_motor_switch(fliM~4)  k_bind
    Growing_flagellar_motor_switch(fliM~4) + fliM() -> Growing_flagellar_motor_switch(fliM~5)  k_bind
    Growing_flagellar_motor_switch(fliM~5) + fliM() -> Growing_flagellar_motor_switch(fliM~6)  k_bind
    Growing_flagellar_motor_switch(fliM~6) + fliM() -> Growing_flagellar_motor_switch(fliM~7)  k_bind
    Growing_flagellar_motor_switch(fliM~7) + fliM() -> Growing_flagellar_motor_switch(fliM~8)  k_bind
    Growing_flagellar_motor_switch(fliM~8) + fliM() -> Growing_flagellar_motor_switch(fliM~9)  k_bind
    Growing_flagellar_motor_switch(fliM~9) + fliM() -> Growing_flagellar_motor_switch(fliM~10)  k_bind
    Growing_flagellar_motor_switch(fliM~10) + fliM() -> Growing_flagellar_motor_switch(fliM~11)  k_bind
    Growing_flagellar_motor_switch(fliM~11) + fliM() -> Growing_flagellar_motor_switch(fliM~12)  k_bind
    Growing_flagellar_motor_switch(fliM~12) + fliM() -> Growing_flagellar_motor_switch(fliM~13)  k_bind
    Growing_flagellar_motor_switch(fliM~13) + fliM() -> Growing_flagellar_motor_switch(fliM~14)  k_bind
    Growing_flagellar_motor_switch(fliM~14) + fliM() -> Growing_flagellar_motor_switch(fliM~15)  k_bind
    Growing_flagellar_motor_switch(fliM~15) + fliM() -> Growing_flagellar_motor_switch(fliM~16)  k_bind
    Growing_flagellar_motor_switch(fliM~16) + fliM() -> Growing_flagellar_motor_switch(fliM~17)  k_bind
    Growing_flagellar_motor_switch(fliM~17) + fliM() -> Growing_flagellar_motor_switch(fliM~18)  k_bind
    Growing_flagellar_motor_switch(fliM~18) + fliM() -> Growing_flagellar_motor_switch(fliM~19)  k_bind
    Growing_flagellar_motor_switch(fliM~19) + fliM() -> Growing_flagellar_motor_switch(fliM~20)  k_bind
    Growing_flagellar_motor_switch(fliM~20) + fliM() -> Growing_flagellar_motor_switch(fliM~21)  k_bind
    Growing_flagellar_motor_switch(fliM~21) + fliM() -> Growing_flagellar_motor_switch(fliM~22)  k_bind
    Growing_flagellar_motor_switch(fliM~22) + fliM() -> Growing_flagellar_motor_switch(fliM~23)  k_bind
    Growing_flagellar_motor_switch(fliM~23) + fliM() -> Growing_flagellar_motor_switch(fliM~24)  k_bind
    Growing_flagellar_motor_switch(fliM~24) + fliM() -> Growing_flagellar_motor_switch(fliM~25)  k_bind
    Growing_flagellar_motor_switch(fliM~25) + fliM() -> Growing_flagellar_motor_switch(fliM~26)  k_bind
    Growing_flagellar_motor_switch(fliM~26) + fliM() -> Growing_flagellar_motor_switch(fliM~27)  k_bind
    Growing_flagellar_motor_switch(fliM~27) + fliM() -> Growing_flagellar_motor_switch(fliM~28)  k_bind
    Growing_flagellar_motor_switch(fliM~28) + fliM() -> Growing_flagellar_motor_switch(fliM~29)  k_bind
    Growing_flagellar_motor_switch(fliM~29) + fliM() -> Growing_flagellar_motor_switch(fliM~30)  k_bind
    Growing_flagellar_motor_switch(fliM~30) + fliM() -> Growing_flagellar_motor_switch(fliM~31)  k_bind
    Growing_flagellar_motor_switch(fliM~31) + fliM() -> Growing_flagellar_motor_switch(fliM~32)  k_bind
    Growing_flagellar_motor_switch(fliM~32) + fliM() -> Growing_flagellar_motor_switch(fliM~33)  k_bind
    Growing_flagellar_motor_switch(fliM~33) + fliM() -> Growing_flagellar_motor_switch(fliM~34)  k_bind
    # Completion
    Growing_flagellar_motor_switch(fliG~26,fliM~34,fliN~1) -> flagellar_motor_switch()  k_completion

    # === flagellar export apparatus reaction 1 ===
    # Product: flagellar export apparatus subunit
    # Subunits: 1x flhA, 1x flhB, 1x fliO, 1x fliP, 1x fliQ, 1x fliR, 1x fliJ, 6x fliI
    # Nucleation (rate scaled by 1/total_subunits)
    flhA() + flhB() -> Growing_flagellar_export_apparatus_subunit(flhA~1,flhB~1,fliI~0,fliJ~0,fliO~0,fliP~0,fliQ~0,fliR~0)  k_nuc_flagellar_export_apparatus_subunit
    Growing_flagellar_export_apparatus_subunit(fliI~0) + fliI() -> Growing_flagellar_export_apparatus_subunit(fliI~1)  k_bind
    Growing_flagellar_export_apparatus_subunit(fliI~1) + fliI() -> Growing_flagellar_export_apparatus_subunit(fliI~2)  k_bind
    Growing_flagellar_export_apparatus_subunit(fliI~2) + fliI() -> Growing_flagellar_export_apparatus_subunit(fliI~3)  k_bind
    Growing_flagellar_export_apparatus_subunit(fliI~3) + fliI() -> Growing_flagellar_export_apparatus_subunit(fliI~4)  k_bind
    Growing_flagellar_export_apparatus_subunit(fliI~4) + fliI() -> Growing_flagellar_export_apparatus_subunit(fliI~5)  k_bind
    Growing_flagellar_export_apparatus_subunit(fliI~5) + fliI() -> Growing_flagellar_export_apparatus_subunit(fliI~6)  k_bind
    Growing_flagellar_export_apparatus_subunit(fliJ~0) + fliJ() -> Growing_flagellar_export_apparatus_subunit(fliJ~1)  k_bind
    Growing_flagellar_export_apparatus_subunit(fliO~0) + fliO() -> Growing_flagellar_export_apparatus_subunit(fliO~1)  k_bind
    Growing_flagellar_export_apparatus_subunit(fliP~0) + fliP() -> Growing_flagellar_export_apparatus_subunit(fliP~1)  k_bind
    Growing_flagellar_export_apparatus_subunit(fliQ~0) + fliQ() -> Growing_flagellar_export_apparatus_subunit(fliQ~1)  k_bind
    Growing_flagellar_export_apparatus_subunit(fliR~0) + fliR() -> Growing_flagellar_export_apparatus_subunit(fliR~1)  k_bind
    # Completion
    Growing_flagellar_export_apparatus_subunit(flhA~1,flhB~1,fliI~6,fliJ~1,fliO~1,fliP~1,fliQ~1,fliR~1) -> flagellar_export_apparatus_subunit()  k_completion

    # === flagellar export apparatus reaction 2 ===
    # Product: flagellar export apparatus
    # Subunits: 1x flagellar export apparatus subunit, 12x fliH
    # Nucleation (rate scaled by 1/total_subunits)
    flagellar_export_apparatus_subunit() + fliH() -> Growing_flagellar_export_apparatus(flagellar_export_apparatus_subunit~1,fliH~1)  k_nuc_flagellar_export_apparatus
    Growing_flagellar_export_apparatus(fliH~1) + fliH() -> Growing_flagellar_export_apparatus(fliH~2)  k_bind
    Growing_flagellar_export_apparatus(fliH~2) + fliH() -> Growing_flagellar_export_apparatus(fliH~3)  k_bind
    Growing_flagellar_export_apparatus(fliH~3) + fliH() -> Growing_flagellar_export_apparatus(fliH~4)  k_bind
    Growing_flagellar_export_apparatus(fliH~4) + fliH() -> Growing_flagellar_export_apparatus(fliH~5)  k_bind
    Growing_flagellar_export_apparatus(fliH~5) + fliH() -> Growing_flagellar_export_apparatus(fliH~6)  k_bind
    Growing_flagellar_export_apparatus(fliH~6) + fliH() -> Growing_flagellar_export_apparatus(fliH~7)  k_bind
    Growing_flagellar_export_apparatus(fliH~7) + fliH() -> Growing_flagellar_export_apparatus(fliH~8)  k_bind
    Growing_flagellar_export_apparatus(fliH~8) + fliH() -> Growing_flagellar_export_apparatus(fliH~9)  k_bind
    Growing_flagellar_export_apparatus(fliH~9) + fliH() -> Growing_flagellar_export_apparatus(fliH~10)  k_bind
    Growing_flagellar_export_apparatus(fliH~10) + fliH() -> Growing_flagellar_export_apparatus(fliH~11)  k_bind
    Growing_flagellar_export_apparatus(fliH~11) + fliH() -> Growing_flagellar_export_apparatus(fliH~12)  k_bind
    # Completion
    Growing_flagellar_export_apparatus(flagellar_export_apparatus_subunit~1,fliH~12) -> flagellar_export_apparatus()  k_completion

    # === flagellar motor reaction ===
    # Product: flagellar motor
    # Subunits: 1x flagellar motor switch, 2x fliL, 1x flgH, 1x motA, 1x motB, 1x flgB, 1x flgC, 1x flgF, 1x flgG, 1x flgI, 1x fliF, 1x fliE
    # Nucleation (rate scaled by 1/total_subunits)
    flagellar_motor_switch() + flgH() -> Growing_flagellar_motor(flagellar_motor_switch~1,flgB~0,flgC~0,flgF~0,flgG~0,flgH~1,flgI~0,fliE~0,fliF~0,fliL~0,motA~0,motB~0)  k_nuc_flagellar_motor
    Growing_flagellar_motor(flgB~0) + flgB() -> Growing_flagellar_motor(flgB~1)  k_bind
    Growing_flagellar_motor(flgC~0) + flgC() -> Growing_flagellar_motor(flgC~1)  k_bind
    Growing_flagellar_motor(flgF~0) + flgF() -> Growing_flagellar_motor(flgF~1)  k_bind
    Growing_flagellar_motor(flgG~0) + flgG() -> Growing_flagellar_motor(flgG~1)  k_bind
    Growing_flagellar_motor(flgI~0) + flgI() -> Growing_flagellar_motor(flgI~1)  k_bind
    Growing_flagellar_motor(fliE~0) + fliE() -> Growing_flagellar_motor(fliE~1)  k_bind
    Growing_flagellar_motor(fliF~0) + fliF() -> Growing_flagellar_motor(fliF~1)  k_bind
    Growing_flagellar_motor(fliL~0) + fliL() -> Growing_flagellar_motor(fliL~1)  k_bind
    Growing_flagellar_motor(fliL~1) + fliL() -> Growing_flagellar_motor(fliL~2)  k_bind
    Growing_flagellar_motor(motA~0) + motA() -> Growing_flagellar_motor(motA~1)  k_bind
    Growing_flagellar_motor(motB~0) + motB() -> Growing_flagellar_motor(motB~1)  k_bind
    # Completion
