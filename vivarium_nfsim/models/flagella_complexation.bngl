    # === flagellum reaction ===
    # Product: flagella
    # Subunits: 1x flagellar export apparatus, 1x flagellar motor, 1x fliC, 1x flgL, 1x flgK, 5x fliD, 1x flagellar hook
    # Nucleation (rate scaled by 1/total_subunits)
    flagellar_export_apparatus() + flagellar_motor() -> Growing_flagella(flagellar_export_apparatus~1,flagellar_hook~0,flagellar_motor~1,flgK~0,flgL~0,fliC~0,fliD~0)  k_nuc_flagella
